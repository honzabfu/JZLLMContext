    "about.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : { "stringUnit" : { "state" : "translated", "value" : "Zpracovává obsah schránky (text i obrázky) pomocí jazykových modelů. Definuj vlastní akce se systémovými prompty a spouštěj je globální klávesovou zkratkou." } },
